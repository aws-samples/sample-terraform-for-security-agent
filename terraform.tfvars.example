# Example Terraform variables file
# Copy this to terraform.tfvars and customize as needed

# AWS region
aws_region = "us-east-1"

# Resource naming (optional — if not provided, random suffix will be used)
# name_postfix = "v1"

# Agent Space configuration
agent_space_name        = "MyAppSecuritySpace"
agent_space_description = "Pentests for my web application"

# Part 2 (Optional): Register a target domain for verification
# target_domain = "your-domain.example.com"
# target_domain_verification_method = "DNS_TXT"

# Part 3 (Optional): Create a pentest
# Set create_pentest = true and provide target endpoints
# create_pentest   = true
# pentest_title    = "Q2-Security-Review"
# target_endpoints = ["https://your-domain.example.com"]

# Tags for all resources
tags = {
  Environment = "production"
  Project     = "aws-security-agent"
  Owner       = "security-team"
}
